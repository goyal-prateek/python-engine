# Copy to `.env` and fill in values. No spaces around `=`.

# --- App / runtime ---
# ENVIRONMENT: local | development | production (see apps/www/core/config.py)
ENVIRONMENT=local

# --- LLM (common/core/common_settings.py) ---
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# --- Google / Gemini ---
GOOGLE_PROJECT_ID=
GOOGLE_API_KEY=
GEMINI_API_KEY=

# --- AWS ---
AWS_REGION=ap-south-1
AWS_ACCESS_KEY=
AWS_SECRET_ACCESS_KEY=

# --- Mongo (optional; omit MONGO_URI to disable) ---
MONGO_URI=
MONGO_DB_NAME=python_engine

# --- TTS / speech ---
ELEVEN_LABS_API_KEY=
SMALLEST_AI_API_KEY=
DEEPGRAM_API_KEY=

# --- Realtime ---
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Observability ---
LOGFIRE_TOKEN=
